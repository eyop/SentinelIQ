# SentinelIQ example environment variables
# Copy to .env and fill with real values.

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Pinecone (optional)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-west1-gcp

# Elasticsearch
ELASTIC_URL=http://localhost:9200
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=changeme

# PostgreSQL
POSTGRES_USER=sentineliq
POSTGRES_PASSWORD=sentineliq
POSTGRES_DB=sentineliq
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sentineliq:sentineliq@postgres:5432/sentineliq

# Redis
REDIS_URL=redis://localhost:6379/0

# App settings
SECRET_KEY=replace-with-a-secure-random-string
ENV=development
LOG_LEVEL=INFO

# Optional: Pinecone/Redis vectorstore toggle
VECTORSTORE=pinecone  # or redis